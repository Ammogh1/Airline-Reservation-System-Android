<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <application
        android:allowBackup="true"
        android:icon="@drawable/ic_plane"
        android:label="@string/app_name"
        android:roundIcon="@drawable/ic_plane"
        android:supportsRtl="true"
        android:theme="@style/Theme.AirlineReservation">
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".activities.LoginActivity" />
        <activity android:name=".activities.RegisterActivity" />
        <activity android:name=".activities.HomeActivity" />
        <activity android:name=".activities.FlightSearchActivity" />
        <activity android:name=".activities.FlightResultsActivity" />
        <activity android:name=".activities.BookingActivity" />
        <activity android:name=".activities.MyTicketsActivity" />
        <activity android:name=".activities.AdminDashboardActivity" />
        <activity android:name=".activities.AddEditFlightActivity" />
        <activity android:name=".activities.AdminViewBookingsActivity" />
    </application>

</manifest>
